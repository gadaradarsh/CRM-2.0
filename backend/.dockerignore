# Dependencies — never copy these into the image
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Secrets — never bake credentials into an image
.env
.env.*
!.env.example

# Dev tooling
.git/
.gitignore
*.md
README*

# OS junk
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp
*.swo

# Test artifacts
coverage/
*.test.js
*.spec.js
__tests__/
